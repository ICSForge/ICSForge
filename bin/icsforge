#!/usr/bin/env python3
"""ICSForge launcher (smooth runtime).

Usage:
  ./bin/icsforge install
  ./bin/icsforge web [--host 0.0.0.0 --port 8080] [--unprivileged]
  ./bin/icsforge receiver [--host 0.0.0.0 --port 9090]
  ./bin/icsforge viewer [--host 0.0.0.0 --port 3000] [--eve-path /path/to/eve.json]
  ./bin/icsforge viewer-replay PCAP [PCAP...] [--port 3000]
  ./bin/icsforge demo {up|down|fire CAMPAIGN}
  ./bin/icsforge selftest
  ./bin/icsforge doctor

Ports:
  Sender   web UI defaults to :8080
  Receiver web UI defaults to :9090  (safe for single-host testing)
  Viewer   alert UI defaults to :3000

The "viewer-replay" mode runs Suricata against your PCAP(s) using
ICSForge's three-tier rules and serves the resulting alerts at :3000.
Useful when you don't want to bring up the full docker stack.

The "demo" mode wraps `docker compose -f docker-compose.demo.yml`:
  demo up                — bring up sender + receiver + Suricata + viewer
  demo down              — tear it all down
  demo fire CAMPAIGN     — run a campaign against the demo stack
"""

import json
import os
import shutil
import subprocess
import sys
import venv
from pathlib import Path

REPO = Path(__file__).resolve().parents[1]
VENV_DIR = REPO / ".venv"
PY = VENV_DIR / ("Scripts/python.exe" if os.name == "nt" else "bin/python")
PIP = VENV_DIR / ("Scripts/pip.exe" if os.name == "nt" else "bin/pip")
REQ = REPO / "requirements.txt"


def _ensure_venv():
    if not PY.exists():
        print("[*] Creating venv at .venv")
        venv.EnvBuilder(with_pip=True, clear=False).create(VENV_DIR)
    if REQ.exists():
        print("[*] Installing requirements")
        subprocess.check_call([str(PIP), "install", "-r", str(REQ)])


def _need_root():
    try:
        import socket
        s = socket.socket(socket.AF_INET, socket.SOCK_RAW, socket.IPPROTO_TCP)
        s.close()
        return False
    except Exception:
        return True


def _rerun_with_sudo():
    if os.name == "nt":
        return False
    if hasattr(os, "geteuid") and os.geteuid() == 0:
        return False
    sudo = shutil.which("sudo")
    if not sudo:
        return False
    print("[*] Elevating with sudo for raw-socket capability (live traffic).")
    os.execvp(sudo, [sudo, "-E", str(PY)] + sys.argv[1:])


def cmd_install(args):
    _ensure_venv()
    print("[+] Done. Use: ./bin/icsforge web  (or receiver/selftest/doctor)")


def cmd_web(args):
    _ensure_venv()
    unpriv = "--unprivileged" in args
    if not unpriv and _need_root():
        _rerun_with_sudo()
    host = "0.0.0.0"
    port = "8080"
    if "--host" in args:
        host = args[args.index("--host") + 1]
    if "--port" in args:
        port = args[args.index("--port") + 1]
    env = os.environ.copy()
    env["ICSFORGE_UI_MODE"] = "sender"
    env["PYTHONPATH"] = str(REPO) + os.pathsep + env.get("PYTHONPATH", "")
    cmd = [str(PY), "-m", "icsforge.web", "--host", host, "--port", port]
    subprocess.check_call(cmd, cwd=str(REPO), env=env)


def cmd_receiver(args):
    _ensure_venv()
    host = "0.0.0.0"
    port = "9090"
    if "--host" in args:
        host = args[args.index("--host") + 1]
    if "--port" in args:
        port = args[args.index("--port") + 1]
    env = os.environ.copy()
    env["ICSFORGE_UI_MODE"] = "receiver"
    env["PYTHONPATH"] = str(REPO) + os.pathsep + env.get("PYTHONPATH", "")
    cmd = [str(PY), "-m", "icsforge.receiver", "--host", host, "--port", port]
    # Forward any extra args (e.g. --l2-iface eth0, --no-web, --bind)
    skip_next = False
    for arg in args:
        if skip_next:
            skip_next = False
            continue
        if arg in ("--host", "--port"):
            skip_next = True
            continue
        cmd.append(arg)
    subprocess.check_call(cmd, cwd=str(REPO), env=env)


def cmd_viewer(args):
    """Live Suricata EVE alert viewer (port 3000)."""
    _ensure_venv()
    host = "0.0.0.0"
    port = "3000"
    eve_path = "/var/log/suricata/eve.json"
    if "--host" in args:
        host = args[args.index("--host") + 1]
    if "--port" in args:
        port = args[args.index("--port") + 1]
    if "--eve-path" in args:
        eve_path = args[args.index("--eve-path") + 1]
    env = os.environ.copy()
    env["PYTHONPATH"] = str(REPO) + os.pathsep + env.get("PYTHONPATH", "")
    env["ICSFORGE_EVE_PATH"] = eve_path
    cmd = [str(PY), "-m", "icsforge.cli", "viewer", "serve",
           "--host", host, "--port", port, "--eve-path", eve_path]
    subprocess.check_call(cmd, cwd=str(REPO), env=env)


def cmd_viewer_replay(args):
    """Run Suricata against PCAP(s) then serve alerts at port 3000."""
    _ensure_venv()
    if not args or args[0].startswith("--"):
        print("Usage: ./bin/icsforge viewer-replay PCAP [PCAP...] [--port 3000]")
        sys.exit(2)
    if not shutil.which("suricata"):
        print("ERROR: suricata is not installed. Install it (apt install suricata)")
        print("       or use the docker stack: docker compose -f docker-compose.demo.yml up")
        sys.exit(2)
    env = os.environ.copy()
    env["PYTHONPATH"] = str(REPO) + os.pathsep + env.get("PYTHONPATH", "")
    cmd = [str(PY), "-m", "icsforge.cli", "viewer", "replay"] + args
    subprocess.check_call(cmd, cwd=str(REPO), env=env)


def cmd_demo(args):
    """Wrap docker-compose for the demo stack.

    Usage:
        ./bin/icsforge demo up                    # bring up demo stack
        ./bin/icsforge demo down                  # tear down
        ./bin/icsforge demo fire CAMPAIGN [-n N]  # run a campaign against the demo stack

    Requires: docker + docker compose, plus the optional dependencies installed
    by `./bin/icsforge install`.
    """
    if not args:
        print("Usage: ./bin/icsforge demo {up|down|fire CAMPAIGN [-n N]}")
        sys.exit(2)
    if not shutil.which("docker"):
        print("ERROR: docker is not installed. The demo stack runs in containers.")
        sys.exit(2)
    sub = args[0]
    rest = args[1:]
    compose_file = REPO / "docker-compose.demo.yml"
    if not compose_file.exists():
        print(f"ERROR: {compose_file} not found")
        sys.exit(2)
    if sub == "up":
        # docker compose v2 syntax (subcommand) with v1 fallback
        cmd = ["docker", "compose", "-f", str(compose_file), "up", "-d"] + rest
        print(f"[*] {' '.join(cmd)}")
        try:
            subprocess.check_call(cmd, cwd=str(REPO))
        except subprocess.CalledProcessError:
            # fallback to docker-compose v1 hyphen
            cmd = ["docker-compose", "-f", str(compose_file), "up", "-d"] + rest
            subprocess.check_call(cmd, cwd=str(REPO))
        print()
        print("Demo stack is up:")
        print("  Sender Web UI:    http://localhost:8080")
        print("  Walk-up demo:     http://localhost:8080/demo")
        print("  Receiver Web UI:  http://localhost:9090")
        print("  Alert viewer:     http://localhost:3000")
    elif sub == "down":
        cmd = ["docker", "compose", "-f", str(compose_file), "down"] + rest
        print(f"[*] {' '.join(cmd)}")
        try:
            subprocess.check_call(cmd, cwd=str(REPO))
        except subprocess.CalledProcessError:
            cmd = ["docker-compose", "-f", str(compose_file), "down"] + rest
            subprocess.check_call(cmd, cwd=str(REPO))
    elif sub == "fire":
        if not rest:
            print("Usage: ./bin/icsforge demo fire CAMPAIGN [-n N]")
            sys.exit(2)
        _ensure_venv()
        env = os.environ.copy()
        env["PYTHONPATH"] = str(REPO) + os.pathsep + env.get("PYTHONPATH", "")
        cmd = [str(PY), "-m", "icsforge.cli", "campaign", "run"] + rest
        subprocess.check_call(cmd, cwd=str(REPO), env=env)
    else:
        print(f"Unknown demo subcommand: {sub}")
        print("Usage: ./bin/icsforge demo {up|down|fire CAMPAIGN [-n N]}")
        sys.exit(2)


def cmd_selftest(args):
    _ensure_venv()
    env = os.environ.copy()
    env["ICSFORGE_UI_MODE"] = "receiver"
    env["PYTHONPATH"] = str(REPO) + os.pathsep + env.get("PYTHONPATH", "")
    cmd = [str(PY), "-m", "icsforge.cli", "selftest", "--live"]
    subprocess.check_call(cmd, cwd=str(REPO), env=env)


def cmd_doctor(args):
    _ensure_venv()
    info = {
        "repo": str(REPO),
        "venv": str(VENV_DIR),
        "raw_socket_needed_for_live_send": _need_root(),
    }
    print(json.dumps(info, indent=2))
    print("\nTips:")
    print("- Live traffic send requires raw sockets (launcher will sudo -E).")
    print("- PCAP generation does not require sudo.")
    print("- Sender: :8080   Receiver: :9090")


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help", "help"):
        print(__doc__)
        sys.exit(0)
    cmd = sys.argv[1]
    args = sys.argv[2:]
    dispatch = {
        "install": cmd_install,
        "web": cmd_web,
        "receiver": cmd_receiver,
        "viewer": cmd_viewer,
        "viewer-replay": cmd_viewer_replay,
        "demo": cmd_demo,
        "selftest": cmd_selftest,
        "doctor": cmd_doctor,
    }
    fn = dispatch.get(cmd)
    if fn:
        fn(args)
    else:
        print(f"Unknown command: {cmd}")
        print(__doc__)
        sys.exit(2)


if __name__ == "__main__":
    main()
